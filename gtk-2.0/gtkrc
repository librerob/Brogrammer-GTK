# Based on Bridge by ScionicSpectre
# vim:set ts=2 sw=2 sts=2 ai et:
#
# GTK2 Adwaita port adjusted to Gruvbox Dark palette

# Text/base
gtk-color-scheme = "text_color:#ebdbb2\nbase_color:#282828"

# Foreground/background
gtk-color-scheme = "fg_color:#ebdbb2\nbg_color:#282828"

# Selected foreground/background
gtk-color-scheme = "selected_fg_color:#ebdbb2\nselected_bg_color:#458588"

# Insensitive foreground/background
gtk-color-scheme = "insensitive_fg_color:#928374\ninsensitive_bg_color:#3c3836"

# Menus
gtk-color-scheme = "menu_color:#282828"

# Links
gtk-color-scheme = "link_color:#458588\nvisited_link_color:#b16286"

# Treeview headers
gtk-color-scheme = "column_header_color:#a89984\nhover_column_header_color:#ebdbb2"

# Window decoration
gtk-color-scheme = "window_color:#282828"

# Tooltips
gtk-color-scheme = "tooltip_fg_color:#ebdbb2\ntooltip_bg_color:#3c3836"


# GTK settings
gtk-auto-mnemonics              = 1
gtk-primary-button-warps-slider = 1


# Load theme components
include "main.rc"
include "apps.rc"
include "hacks.rc"
include "hacks-dark.rc"
