# Based on Bridge by ScionicSpectre
# vim:set ts=2 sw=2 sts=2 ai et:
#
# GTK2 Adwaita port adjusted to Gruvbox Dark palette

# Text/base
gtk-color-scheme = "text_color:#d6dbe5\nbase_color:#1f1f1f"

# Foreground/background
gtk-color-scheme = "fg_color:#d6dbe5\nbg_color:#1f1f1f"

# Selected foreground/background
gtk-color-scheme = "selected_fg_color:#d6dbe5\nselected_bg_color:#2a84d2"

# Insensitive foreground/background
gtk-color-scheme = "insensitive_fg_color:#4e4e4e\ninsensitive_bg_color:#2e2e2e"

# Menus
gtk-color-scheme = "menu_color:#1f1f1f"

# Links
gtk-color-scheme = "link_color:#2a84d2\nvisited_link_color:#4e5ab7"

# Treeview headers
gtk-color-scheme = "column_header_color:#606570\nhover_column_header_color:#d6dbe5"

# Window decoration
gtk-color-scheme = "window_color:#1f1f1f"

# Tooltips
gtk-color-scheme = "tooltip_fg_color:#d6dbe5\ntooltip_bg_color:#2e2e2e"


# GTK settings
gtk-auto-mnemonics              = 1
gtk-primary-button-warps-slider = 1


# Load theme components
include "main.rc"
include "apps.rc"
include "hacks.rc"
include "hacks-dark.rc"
